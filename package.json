{
  "name": "line-order-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "author": "webdev-jp-net",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint:script": "eslint .",
    "lint:style": "stylelint src/**/*.scss",
    "lint:fix": "eslint . --fix && stylelint src/**/*.scss --fix",
    "lint": "pnpm run lint:script && pnpm run lint:style",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,scss,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,scss,md}\"",
    "api:gen": "npx @rtk-query/codegen-openapi src/api/openapi-config.cjs",
    "mock-api": "prism mock ./src/api/api-structure.yaml -p 4010",
    "scaffold": "scaffdog generate",
    "prebuild": "sh src/data/generator/_getApiData.sh && node src/data/generator/_generateCustomJson.js && sh src/data/getMedia.sh",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepare": "husky"
  },
  "dependencies": {
    "@dr.pogodin/react-helmet": "^2.0.4",
    "@headlessui/react": "^2.2.8",
    "@line/liff": "^2.27.2",
    "@line/liff-mock": "^1.0.3",
    "@reduxjs/toolkit": "^2.8.2",
    "@uidotdev/usehooks": "^2.4.1",
    "dayjs": "^1.11.18",
    "lucide-react": "^0.544.0",
    "modern-css-reset": "^1.4.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-redux": "^9.2.0",
    "react-router": "^7.7.0",
    "react-router-dom": "7.7.0",
    "redux-persist": "^6.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@rtk-query/codegen-openapi": "^2.2.0",
    "@stoplight/prism-cli": "^5.15.11",
    "@storybook/addon-docs": "^9.0.18",
    "@storybook/addon-links": "^9.0.18",
    "@storybook/react": "^9.0.18",
    "@storybook/react-vite": "^9.0.18",
    "@stylelint/postcss-css-in-js": "^0.38.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/redux-persist": "^4.3.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "eslint-plugin-storybook": "^9.0.18",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.6.2",
    "sass": "^1.90.0",
    "scaffdog": "^4.1.0",
    "storybook": "^9.0.18",
    "stylelint": "^16.22.0",
    "stylelint-config-recess-order": "^7.1.0",
    "stylelint-config-standard-scss": "^15.0.1",
    "stylelint-order": "^7.0.0",
    "stylelint-scss": "^6.12.1",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.36.0",
    "vite": "^6.0.0",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@parcel/watcher"
    ]
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx}": [
      "bash -c 'files=$(echo \"$0\" | grep -v \"/test/\"); if [ -n \"$files\" ]; then eslint --ext ts,tsx --report-unused-disable-directives --max-warnings 0 $files; fi'"
    ],
    "src/**/*.{css,scss}": [
      "bash -c 'files=$(echo \"$0\" | grep -v \"/test/\"); if [ -n \"$files\" ]; then stylelint $files; fi'"
    ]
  }
}
