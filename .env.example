# 接続先のサーバー(line-order-api)のアドレス。手元で動かす時はこのまま
VITE_API_BASE_URL=http://localhost:8787

# 動作環境。local なら LINE ログインを省略してテストできる
VITE_APP_ENV='local' # local / staging / prod

# LINE ミニアプリの識別ID
VITE_LIFF_ID='xxxxxx'

# メニューを管理する外部サービス(microCMS)への接続情報。アプリには公開しない
MICROCMS_SERVICE='xxxxxx'
MICROCMS_SERVICE_KEY='xxxxxx'
